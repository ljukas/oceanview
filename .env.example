# Local dev points at Neon Local docker proxy on localhost.
# Vercel Preview/Production: DATABASE_URL is auto-provisioned by the Neon Marketplace integration.
DATABASE_URL=postgres://neon:npg@localhost:5432/neondb?sslmode=require

# Personal Neon API key (create at https://console.neon.tech/app/settings/api-keys).
# Used only by the Neon Local container to create/delete ephemeral branches.
NEON_API_KEY=

# Neon project + parent branch IDs (capture once via Neon dashboard or MCP).
# Both are public-ish identifiers; the API key above is the actual secret.
NEON_PROJECT_ID=
PARENT_BRANCH_ID=

# Better Auth — generate via `openssl rand -base64 32`. 32+ chars required.
BETTER_AUTH_SECRET=
# Site origin. Local: http://localhost:3000. Vercel prod: https://oceanview-psi.vercel.app.
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated emails that get auto-promoted to admin role on sign-in.
ADMIN_EMAILS=
