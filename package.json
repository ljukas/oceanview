{
  "name": "oceanview",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:log": "rm -f /tmp/oceanview-dev.log && vite dev 2>&1 | tee /tmp/oceanview-dev.log",
    "build": "vite build && tsc --noEmit",
    "vercel-build": "drizzle-kit migrate && vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "db:up": "docker compose up -d --wait db",
    "db:down": "docker compose down db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "auth:schema": "pnpm dlx @better-auth/cli@1.4.21 generate --yes --output src/lib/db/schema/betterAuth.ts && node scripts/patchBetterAuthSchema.mjs",
    "queue:up": "docker compose up -d --wait queue",
    "queue:down": "docker compose down queue",
    "queue:studio": "docker compose --profile studio up -d queue-studio",
    "storage:up": "docker compose up -d storage storage-init",
    "storage:down": "docker compose down storage storage-init",
    "mail:up": "docker compose up -d --wait mail",
    "mail:down": "docker compose down mail",
    "email:dev": "pnpm dlx react-email dev --dir src/emails --port 14501",
    "dev:up": "docker compose up -d --wait db queue mail && docker compose up -d storage storage-init && pnpm db:migrate",
    "dev:down": "docker compose down",
    "dev:worker": "tsx scripts/devQueueWorker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@better-auth/drizzle-adapter": "^1.6.16",
    "@better-auth/passkey": "^1.6.16",
    "@dnd-kit/accessibility": "^3.1.1",
    "@dnd-kit/core": "^6.3.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@orpc/client": "^1.14.5",
    "@orpc/experimental-publisher": "^1.14.5",
    "@orpc/server": "^1.14.5",
    "@orpc/tanstack-query": "^1.14.5",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@unpic/placeholder": "^0.1.2",
    "@unpic/react": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/functions": "^3.7.0",
    "@vercel/queue": "^0.3.0",
    "better-auth": "^1.6.16",
    "blurhash": "^2.0.5",
    "bullmq": "^5.78.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "exponential-backoff": "^3.1.3",
    "heic-to": "^1.5.2",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.10",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-dropzone": "^15.0.0",
    "react-email": "^6.6.0",
    "react-phone-number-input": "^3.4.17",
    "resend": "^6.12.4",
    "shadcn": "^4.11.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "unpic": "^4.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.7.0",
    "@types/node": "^24.13.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "nitro": "3.0.260603-beta",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
