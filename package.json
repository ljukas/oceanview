    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "nitro": "^3.0.260311-beta",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
