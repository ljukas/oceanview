{
  "name": "oceanview",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:log": "rm -f /tmp/oceanview-dev.log && vite dev 2>&1 | tee /tmp/oceanview-dev.log",
    "build": "vite build && tsc --noEmit",
    "vercel-build": "drizzle-kit migrate && vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs",
    "db:up": "docker compose up -d --wait db",
    "db:down": "docker compose down db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "queue:up": "docker compose up -d --wait queue",
    "queue:down": "docker compose down queue",
    "queue:studio": "docker compose --profile studio up -d queue-studio",
    "storage:up": "docker compose up -d storage storage-init",
    "storage:down": "docker compose down storage storage-init",
    "dev:up": "docker compose up -d --wait db queue && docker compose up -d storage storage-init && pnpm db:migrate",
    "dev:down": "docker compose down",
    "dev:worker": "tsx scripts/devBlurhashWorker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check --write .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/passkey": "^1.6.11",
    "@fontsource-variable/geist": "^5.2.8",
    "@orpc/client": "^1.14.3",
    "@orpc/experimental-publisher": "^1.14.3",
    "@orpc/server": "^1.14.3",
    "@orpc/tanstack-query": "^1.14.3",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.167.65",
    "@unpic/placeholder": "^0.1.2",
    "@unpic/react": "^1.0.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "@vercel/queue": "^0.2.0",
    "better-auth": "^1.6.11",
    "blurhash": "^2.0.5",
    "bullmq": "^5.77.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "exponential-backoff": "^3.1.3",
    "heic-to": "^1.4.3",
    "lucide-react": "^1.16.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-phone-number-input": "^3.4.16",
    "shadcn": "^4.7.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tw-animate-css": "^1.4.0",
    "unpic": "^4.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/devtools-vite": "^0.7.0",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "nitro": "3.0.260522-beta",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
